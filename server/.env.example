PORT=3000

# MySQL (required for multi-device sync)
# Run once: mysql -u root -p < setup-db.sql  (creates DB and user 'ganesh')
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=ganesh
MYSQL_PASSWORD=ganesh
MYSQL_DATABASE=ganesh_jewellers

# JWT secret (change in production)
JWT_SECRET=ganesh-jewellers-secret-change-in-production

# Razorpay (for UPI/Card payments)
RAZORPAY_KEY_ID=your_key_id
RAZORPAY_KEY_SECRET=your_key_secret
APP_SCHEME=ganeshjewellers
